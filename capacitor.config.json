{
  "appId": "com.sobressemanales.app",
  "appName": "Sobres Semanales",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "url": "https://sobres-semanales.vercel.app"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#0B7A4B",
      "showSpinner": false,
      "launchAutoHide": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0B7A4B"
    }
  },
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#F6F4ED"
  }
}
